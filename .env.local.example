# =============================================================
# Digitális Kárfelvételi Platform — Környezeti változók sablon
# Másold át .env.local névvel és töltsd ki az értékeket!
# Ez a fájl (example) kerülhet Git-be – a tényleges .env.local NEM!
# =============================================================

# PostgreSQL kapcsolat (Supabase → Settings → Database → Connection string)
DATABASE_URL=""
# Supabase direkt kapcsolat (migrációkhoz, connection pooler nélkül)
DIRECT_URL=""

# Resend API kulcs (resend.com → API Keys)
RESEND_API_KEY=""

# Email beállítások
WORKSHOP_EMAIL=""         # A műhely email címe (ide megy az értesítő)
EMAIL_FROM=""             # Feladó cím, pl: "Kárfelvétel <no-reply@domained.hu>"

# Alkalmazás URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Upstash Redis (rate limiting) – upstash.com → Redis → REST API
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Supabase (Storage – aláírás feltöltés)
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""  # Csak szerver oldalon! Soha ne kerüljön kliensre.
